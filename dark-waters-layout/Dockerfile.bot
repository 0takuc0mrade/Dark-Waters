FROM node:22-slim
WORKDIR /app
# Copy package files and install
COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps --omit=dev
# Copy bot code and supporting files
COPY scripts/bot-runner.mjs scripts/
COPY src/ src/
# Session volume mount point
RUN mkdir -p /data/session
ENV NODE_ENV=production
ENV BOT_ALLOW_INTERACTIVE_AUTH=false
ENV BOT_POLL_MS=4000
ENV BOT_SESSION_BASE_PATH=/data/session
ENV BOT_STATE_PATH=/data/bot-state.json
CMD ["node", "scripts/bot-runner.mjs"]
